{
  "name": "doubtmaster-ai-backend",
  "version": "1.0.0",
  "description": "DoubtMaster AI Backend - India's #1 AI homework solver",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js",
    "lint": "eslint src/",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node src/scripts/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.637.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.19.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.56.0",
    "razorpay": "^2.9.4",
    "sharp": "^0.33.5",
    "stripe": "^16.8.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "prisma": "^5.19.0",
    "supertest": "^7.0.0"
  }
}
