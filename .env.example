# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=info

# ── JWT (generate: make generate-jwt-secret) ──────────────────────────────────
JWT_SECRET=<64-char-minimum-random-string>
JWT_ISSUER=doubtmaster.ai
JWT_AUDIENCE=doubtmaster-api

# ── Database (Railway injects DATABASE_URL automatically in Railway envs) ──────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doubtmaster

# ── Redis (Railway injects REDIS_URL automatically) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM Cost Router ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...         # Tier 3 — $3/$15 per 1M tokens
DEEPSEEK_API_KEY=sk-...              # Tier 2 — $0.28/$0.42 per 1M tokens
TOGETHER_API_KEY=...                 # Tier 1 — $0.15/$0.60 per 1M tokens
NVIDIA_API_KEY=nvapi-...             # Special — FREE pre-processing endpoint (see license warning)

# ── OpenMAIC sidecar ─────────────────────────────────────────────────────────
OPENMAIC_INTERNAL_URL=http://localhost:3001   # local dev; Railway injects internal URL

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
